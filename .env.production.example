# Copiar para .env.production e preencher antes de subir o container
# NUNCA commitar o .env.production real

NODE_ENV=production

# ─── Supabase ────────────────────────────────────────────────────────────────
# No painel Supabase → Authentication → URL Configuration:
#   Site URL: https://app.suaagenda.pro
#   Redirect URLs:
#     https://app.suaagenda.pro/auth/callback
#     https://app.suaagenda.pro/reset-password
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=seu_project_id
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PROJECT_ID=seu_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=

# URL pública do app (confirmação de e-mail, links OAuth)
VITE_APP_URL=https://app.suaagenda.pro

# ─── Super Admin (JSON array — NUNCA commitar) ───────────────────────────────
SUPER_ADMINS=[{"email":"admin@exemplo.com","name":"Admin","password":"SUA_SENHA_AQUI","must_change_password":false}]

# ─── Segurança ───────────────────────────────────────────────────────────────
# openssl rand -hex 32
APP_HMAC_SECRET=

# ─── Asaas ───────────────────────────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_ENV=production
ASAAS_WEBHOOK_TOKEN=

# ─── Mercado Pago (produção) ───────────────────────────────────────────────────
# Painel: https://www.mercadopago.com.br/developers/panel/app
# Credenciais de PRODUÇÃO (não TEST-). Redirect URI e webhook abaixo.
#
# Redirect URI (OAuth):
#   https://app.suaagenda.pro/api/public/mercado-pago/callback
#
# Webhook produção (evento: payment):
#   https://app.suaagenda.pro/api/public/mp-webhook?source_news=webhooks
#
# MP_WEBHOOK_SECRET = chave revelada em Webhooks > Configurar notificações
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_WEBHOOK_SECRET=
MP_PKCE_ENABLED=true

# ─── Email via Resend ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="suaAgendaPro <noreply@suaagenda.pro>"

# ─── WhatsApp via Evolution API ──────────────────────────────────────────────
# Docker (VPS) lê ESTE arquivo — não o .env local.
# EVOLUTION_GLOBAL_API_KEY=chave global do painel Evolution (GET /instance/all)
# EVOLUTION_API_KEY=token da instancia (envio / worker Supabase)
# EVOLUTION_INSTANCE_ID=UUID da instancia (worker Supabase)
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com
EVOLUTION_GLOBAL_API_KEY=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_ID=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:SENHA@host:6379

# ─── Banco VPS ───────────────────────────────────────────────────────────────
VPS_DATABASE_URL=postgresql://USUARIO:SENHA@host:5432/BANCO
POSTGRES_SSL=true

# ─── Google Calendar OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Tokens internos (openssl rand -hex 32) ──────────────────────────────────
AI_SYNC_TOKEN=
HOSTINGER_API_TOKEN=
HOSTINGER_VM_ID=

# ─── Web Push ────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:privacidade@suaagenda.pro
VITE_VAPID_PUBLIC_KEY=
