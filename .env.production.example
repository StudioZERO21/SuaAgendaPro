# Copiar para .env.production e preencher antes de subir o container
# NUNCA commitar o .env.production real

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Asaas (ETAPA 4) ─────────────────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_ENV=production          # sandbox | production
ASAAS_WEBHOOK_TOKEN=          # token secreto para validar webhooks (gerar aleatório)

# ─── Mercado Pago ────────────────────────────────────────────────────────────
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# (mesmas chaves já usadas no app)

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_SECRET=           # senha extra para rotas /super (ETAPA 7)
