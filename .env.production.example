# Copiar para .env.production e preencher antes de subir o container
# NUNCA commitar o .env.production real

NODE_ENV=production

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://itqsrpmovqeyhzsertqe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=itqsrpmovqeyhzsertqe
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://itqsrpmovqeyhzsertqe.supabase.co
VITE_SUPABASE_PROJECT_ID=itqsrpmovqeyhzsertqe
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Super Admin (JSON array — NUNCA commitar) ───────────────────────────────
# Formato: [{"email":"...","name":"...","password":"...","must_change_password":false}]
SUPER_ADMINS=[{"email":"adrianoelite@msn.com","name":"Adriano Santos","password":"SUA_SENHA_AQUI","must_change_password":false}]

# ─── Asaas ───────────────────────────────────────────────────────────────────
# Chave começa com $ — cole o valor direto (sem escapes), ex: $aact_hmlg_000...
# O Docker lê env_file sem interpolação de variáveis, então $ é tratado literalmente.
ASAAS_API_KEY=
ASAAS_ENV=production
ASAAS_WEBHOOK_TOKEN=

# ─── Mercado Pago ────────────────────────────────────────────────────────────
MP_CLIENT_ID=1827809196108071
MP_CLIENT_SECRET=
MP_WEBHOOK_SECRET=
MP_PKCE_ENABLED=true

# ─── Email via Resend ────────────────────────────────────────────────────────
# Domínio suaagenda.pro verificado em resend.com/domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=suaAgendaPro <noreply@suaagenda.pro>

# ─── WhatsApp via Evolution GO ───────────────────────────────────────────────
EVOLUTION_API_URL=https://evolution-go-ovp8.srv1772059.hstgr.cloud
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_ID=

# ─── Redis (usar o container redis-phqs da VPS) ───────────────────────────────
REDIS_URL=redis://:SENHA_DO_REDIS@187.77.244.198:32773

# ─── Banco de dados VPS (usar postgresql-gfec) ───────────────────────────────
VPS_DATABASE_URL=postgresql://USUARIO:SENHA@187.77.244.198:32774/BANCO

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Tokens internos (gerar com: openssl rand -hex 32) ───────────────────────
AI_SYNC_TOKEN=
HOSTINGER_API_TOKEN=
HOSTINGER_VM_ID=1772059

# ─── Web Push (notificações PWA) ──────────────────────────────────────────────
# Gerar o par de chaves com:  npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY deve ser IGUAL a VAPID_PUBLIC_KEY (o cliente precisa dela).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
